# ---- Core ----
DATABASE_URL=postgresql+psycopg://vulnunify:vulnunify@db:5432/vulnunify
LOG_LEVEL=INFO

# development | production. "production" turns on secure-by-default behavior:
# secure session cookies, same-origin (CSRF) checks on state-changing requests,
# and a required SECRET_KEY (below). Leave as development for local HTTP.
ENVIRONMENT=development

# Encrypts connector credentials stored via the UI. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank for local dev (a key is generated + persisted to .vulnunify_secret_key).
# REQUIRED in production (ENVIRONMENT=production) — the app refuses to boot without it.
SECRET_KEY=

# ---- First-run admin login ----
# A bootstrap admin account is created on first startup (empty database). Set a
# password here to log in right away at http://localhost:8000. If left blank, a
# random password is generated and printed ONCE in the container logs:
#   docker compose logs api | grep seeded_admin
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=

# Cross-origin browser access. Empty = same-origin only (no CORS). Set to a
# comma-separated origin list only if a separate frontend calls this API.
CORS_ALLOW_ORIGINS=

# Force the session cookie's Secure flag. Blank = auto (secure in production,
# off in dev). Set true/false to override.
# SESSION_COOKIE_SECURE=

# Background scheduler: run all configured connectors every N minutes.
# 0 (default) = manual sync only (via POST /api/sync). Set e.g. 360 for every 6 hours.
SYNC_INTERVAL_MINUTES=0

# SLA windows in days from when a finding was first seen, per severity.
SLA_CRITICAL_DAYS=7
SLA_HIGH_DAYS=30
SLA_MEDIUM_DAYS=90
SLA_LOW_DAYS=180

# Notifications: a Slack-compatible incoming webhook (Slack/Mattermost/Rocket.Chat).
# Blank (default) = disabled. Each scheduler tick sends one digest covering new
# high-risk findings, KEV matches, and SLA breaches; each fires once per finding.
# Can also be set (encrypted at rest) from the Connectors & Settings page.
NOTIFY_SLACK_WEBHOOK_URL=
# Alert on open findings with risk score >= this (0-100; 0 disables that rule).
NOTIFY_RISK_THRESHOLD=80

# ---- Connector credentials ----
# Only fill in the ones you use. Each connector reads its own keys.
# A connector with missing/blank credentials is reported as "unconfigured"
# and skipped during sync rather than erroring.

# Tenable.io  (https://developer.tenable.com/)
TENABLE_ACCESS_KEY=
TENABLE_SECRET_KEY=
TENABLE_BASE_URL=https://cloud.tenable.com

# Rapid7 InsightVM Security Console (REST API v3)
RAPID7_BASE_URL=
RAPID7_USERNAME=
RAPID7_PASSWORD=
RAPID7_VERIFY_SSL=true

# Wiz  (GraphQL, OAuth2 client credentials)
WIZ_CLIENT_ID=
WIZ_CLIENT_SECRET=
WIZ_API_URL=https://api.us1.app.wiz.io/graphql
WIZ_AUTH_URL=https://auth.app.wiz.io/oauth/token

# Trend Micro Vision One / Cloud One
TREND_API_KEY=
TREND_BASE_URL=https://api.xdr.trendmicro.com

# Microsoft Defender for Cloud (via Az PowerShell module)
# Auth is handled by the Az context on the host running the PowerShell connector.
DEFENDER_SUBSCRIPTION_ID=
DEFENDER_PWSH_PATH=pwsh

# SonarQube / SonarCloud
SONARQUBE_TOKEN=
SONARQUBE_BASE_URL=https://sonarcloud.io
SONARQUBE_ORGANIZATION=
SONARQUBE_PROJECT_KEYS=

# Aikido
AIKIDO_CLIENT_ID=
AIKIDO_CLIENT_SECRET=
AIKIDO_BASE_URL=https://app.aikido.dev/api

# Semgrep (Semgrep AppSec Platform)
SEMGREP_APP_TOKEN=
SEMGREP_DEPLOYMENT_SLUG=
SEMGREP_BASE_URL=https://semgrep.dev/api

# Snyk (container image scanning, API ingestion)
SNYK_TOKEN=
SNYK_ORG_ID=
SNYK_BASE_URL=https://api.snyk.io
